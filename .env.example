# Stack and ports
STACK_VERSION=2.0.0
OLLAMA_IMAGE=ollama/ollama:latest
OPEN_WEBUI_IMAGE=ghcr.io/open-webui/open-webui:latest
WYOMING_WHISPER_IMAGE=rhasspy/wyoming-whisper:latest
WYOMING_PIPER_IMAGE=rhasspy/wyoming-piper:latest
CADDY_IMAGE=caddy:2.10-alpine
WATCHTOWER_IMAGE=containrrr/watchtower:1.7.1
BACKUP_IMAGE=alpine:3.22
STACK_OPS_IMAGE=alpine:3.22

OLLAMA_PORT=11434
OPEN_WEBUI_PORT=3000
CADDY_HTTP_PORT=80
WYOMING_WHISPER_PORT=10300
WYOMING_PIPER_PORT=10200

# Runtime behavior
OLLAMA_KEEP_ALIVE=24h
SAMATHA_DEFAULT_MODEL=qwen2.5:0.5b
SAMANTHA_MODEL_NAME=samantha
OPEN_WEBUI_AUTH=True
SAMATHA_ENABLE_CODE_INTERPRETER=False
SAMATHA_ENABLE_CODE_EXECUTION=False
SAMATHA_ENABLE_MEMORIES=False
SAMATHA_TOOL_SERVER_CONNECTIONS=[]

# Open WebUI to Ollama
SAMATHA_OLLAMA_BASE_URL=http://ollama:11434
SAMATHA_CONTAINER_API_BASE_URL=http://ollama:11434/v1
SAMATHA_CONTAINER_API_KEY=ollama
SAMATHA_OPENAI_API_BASE_URLS=http://ollama:11434/v1
SAMATHA_OPENAI_API_KEYS=ollama
SAMATHA_MCP_SERVER_URL=http://automation-mcp-server:8080/mcp

# Caddy HTTPS
CADDY_SITE_ADDRESS=rpiai.local
CADDY_EMAIL=admin@example.local
CADDY_PUBLIC_URL=https://rpiai.local:3000

# Wyoming STT/TTS
WYOMING_WHISPER_MODEL=tiny-int8
WYOMING_WHISPER_LANGUAGE=nl
WYOMING_PIPER_VOICE=nl_NL-nathalie-medium
AUDIO_TTS_PROVIDER=wyoming
AUDIO_TTS_URL=tcp://wyoming-piper:10200
AUDIO_STT_PROVIDER=wyoming
AUDIO_STT_URL=tcp://wyoming-whisper:10300
AUDIO_STT_LANGUAGE=nl

# Operations
WATCHTOWER_SCHEDULE=0 0 4 * * *
OPS_LOOP_SECONDS=300
REQUIRE_HTTPS_CHECK=false
BACKUP_INTERVAL_SECONDS=21600
BACKUP_RETENTION_DAYS=14

# MCP server config via .env -> generated config.yaml
MCP_HOMEY_ENABLED=true
MCP_HOMEY_BASE_URL=http://homey
MCP_HOMEY_BEARER_TOKEN=CHANGE_ME_HOMEY_BEARER_TOKEN
MCP_HA1_NAME=home_assistant_1
MCP_HA1_URL=http://192.168.1.80:8123
MCP_HA1_TOKEN=CHANGE_ME_HA1_TOKEN
MCP_HA2_NAME=home_assistant_2
MCP_HA2_URL=http://192.168.1.123:8123
MCP_HA2_TOKEN=CHANGE_ME_HA2_TOKEN
MCP_MONITOR_ENABLED=true
MCP_MONITOR_BASE_URL=http://rpi-monitor:61208/api/4
MCP_JWT_ENABLED=false
MCP_JWT_SECRET_KEY=CHANGE_ME_JWT_SECRET
MCP_JWT_ALGORITHM=HS256
