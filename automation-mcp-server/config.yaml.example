homey:
  enabled: true
  base_url: http://homey
  bearer_token: YOUR_HOMEY_TOKEN
  timeout_seconds: 15

homeassistant:
  instances:
    energie:
      url: http://192.168.1.123:8123
      token: LONG_LIVED_TOKEN
      timeout_seconds: 15
    aanwezigheid:
      url: http://192.168.1.80:8123
      token: LONG_LIVED_TOKEN
      timeout_seconds: 15

monitor:
  enabled: true
  base_url: http://rpi-monitor:61208/api/4
  timeout_seconds: 5

jwt:
  enabled: false
  secret_key: CHANGE_ME
  algorithm: HS256
  audience: null
  issuer: null

server:
  host: 0.0.0.0
  port: 8080
