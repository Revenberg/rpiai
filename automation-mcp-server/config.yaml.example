homey:
  enabled: true
  base_url: http://homey
  bearer_token: CHANGE_ME_HOMEY_BEARER_TOKEN
  timeout_seconds: 15

homeassistant:
  instances:
    home_assistant_1:
      url: http://192.168.1.80:8123
      token: CHANGE_ME_HA1_TOKEN
      timeout_seconds: 15
    home_assistant_2:
      url: http://192.168.1.123:8123
      token: CHANGE_ME_HA2_TOKEN
      timeout_seconds: 15

monitor:
  enabled: true
  base_url: http://rpi-monitor:61208/api/4
  timeout_seconds: 5

jwt:
  enabled: false
  secret_key: CHANGE_ME
  algorithm: HS256
  audience: null
  issuer: null

server:
  host: 0.0.0.0
  port: 8080
